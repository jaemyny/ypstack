# VWorld API 인증키 (필수)
# 발급: https://www.vworld.kr/dev/v4po_main.do > 인증키 발급
VWORLD_API_KEY=your-vworld-api-key-here

# 키 발급 시 등록한 도메인 (개발: localhost)
VWORLD_DOMAIN=localhost

# 공동주택가격 WFS 레이어명
# VWorld 개발자포털 > 오픈API > 국가중점데이터API > 공동주택가격정보 참조
# 기본값 LT_C_APATG. 서버 응답에 INVALID_RANGE 오류가 뜨면 실제 레이어명으로 교체
VWORLD_APT_LAYER=LT_C_APATG

# 좌표 기반 반경 검색 거리 (미터), 기본 300m
SEARCH_RADIUS_M=300
